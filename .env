# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to version control.

# --- Telegram API credentials ---
# Get these from https://my.telegram.org/apps (log in with your phone number,
# create an "app", and you'll receive an api_id and api_hash).
TG_API_ID=37599370
TG_API_HASH=fe5081b4532e930d7783e0c6d38b3cf4
TG_PHONE_NUMBER=+919059661702
TG_SESSION_NAME=stock_alert_session


# --- Target group ---
# Can be the numeric chat ID, the @username of the group, or an invite link
# you have already joined with this account.
TG_GROUP_ID=-1002113826282
TG_CHANNEL_IDS=@VolumeAlerts,@BreakoutAlerts,@OtherAlerts,@20EMA_50EMA,@GMMA_Cloud
# --- Power Automate ---
# The "When an HTTP request is received" trigger URL from your Power Automate flow.
POWER_AUTOMATE_URL=https://defaultb9fec68cc92d461e9a973d03a0f18b.82.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/43245a4738054c04ab5e8952d3cd1cb5/triggers/manual/paths/invoke?api-version=1&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=ac9Du0MBsj-M6h8zHuiDYdr0kgs81fTdMe-sb-xGTG4
